{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    "modules-left": [
        "custom/launcher",
        "niri/workspaces",
        "niri/window"
    ],
    "modules-center": [
        "clock",
        "custom/weather"
    ],
    "modules-right": [
        "niri/language",
        "cpu",
        "memory",
        "disk",
        "group/connection",
        "pulseaudio",
        "battery",
        "tray",
        "custom/power"
    ],
    "custom/launcher": {
        "format": "َ°£‡",
        "on-click": "fuzzel",
        "tooltip": false
    },
    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1-main": "َ°ˆ¹",
            "2-work": "َ°…±",
            "3-chat": "َ°™¯",
            "4-sys": "َ°““",
            "default": "َ°„°"
        }
    },
    "niri/window": {
        "format": "{title}",
        "max-length": 50,
        "separate-outputs": true
    },
    "niri/language": {
        "format": "َ°ŒŒ {}"
    },
    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 3600,
        "exec": "~/.config/waybar/scripts/weather.py",
        "return-type": "json",
        "on-click": "alacritty --title 'Weather Forecast' -e bash -c 'curl -s \"wttr.in/Krasnoyarsk?m\"; echo; echo \"Press any key to close...\"; read -n 1 -s'"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں MUT",
        "format-bluetooth": "َ°•¾ {volume}% ïٹ”",
        "format-icons": {
            "default": [
                "َ°•؟",
                "َ°–€",
                "َ°•¾"
            ]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip": false
    },
    "cpu": {
        "interval": 2,
        "format": "َ°»  {usage}%",
        "tooltip": true
    },
    "memory": {
        "interval": 5,
        "format": "َ°چ› {percentage}%",
        "tooltip-format": "Used: {used}GiB / Total: {total}GiB"
    },
    "disk": {
        "interval": 30,
        "format": "َ°‹ٹ {specific_used:0.1f}G",
        "unit": "GB",
        "path": "/"
    },
    "group/connection": {
        "orientation": "horizontal",
        "modules": [
            "network",
            "custom/wifitemp"
        ]
    },
    "network": {
        "interval": 2,
        "format-wifi": "َ°–© {bandwidthDownBytes}",
        "format-ethernet": "َ°ˆ€ {bandwidthDownBytes}",
        "format-disconnected": "َ°–ھ OFF",
        "tooltip-format": "{ifname}: {ipaddr}\nَ°‡ڑ {bandwidthDownBytes} َ°•’ {bandwidthUpBytes}",
        "min-length": 8
    },
    "custom/wifitemp": {
        "interval": 5,
        "exec": "for tz in /sys/class/thermal/thermal_zone*; do if grep -q 'iwlwifi' \"$tz/type\"; then awk '{printf \"%.0fآ°C\", $1/1000}' \"$tz/temp\"; break; fi; done",
        "format": "َ°”„ {}"
    },
    "battery": {
        "interval": 5,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": [
            "َ°پ؛",
            "َ°پ¼",
            "َ°پ¾",
            "َ°‚€",
            "َ°پ¹"
        ]
    },
    "clock": {
        "format": "َ°ƒ° {:%H:%M  %F}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },
    "custom/power": {
        "format": "ï€‘",
        "tooltip": false,
        "on-click": "~/.config/niri/scripts/power-menu.sh"
    }
}